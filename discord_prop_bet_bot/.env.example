# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# SQLite database file path (created automatically)
DATABASE_PATH=propbot.db

# Starting balance for new users in each server
STARTING_BALANCE=1000

# Seconds between checks for expired open bets
BET_EXPIRY_CHECK_INTERVAL=30

# Auto-refund wagers if a closed bet is not resolved within this time after close
UNRESOLVED_REFUND_AFTER=24h

# LMSR liquidity for prediction markets (higher = stabler prices)
DEFAULT_MARKET_LIQUIDITY=100

# Maximum coins per prediction-market buy
MAX_MARKET_TRADE_COINS=50

# Optional: sync slash commands to one server instantly (right-click server → Copy Server ID).
# Leave blank to sync globally (can take up to ~1 hour to appear everywhere).
DEV_GUILD_ID=

# Optional: lock all commands and bet reactions to one channel (right-click channel → Copy Channel ID).
# Leave blank to allow any channel in the server.
ALLOWED_CHANNEL_ID=
